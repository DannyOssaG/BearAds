# ── ANTHROPIC ──
ANTHROPIC_API_KEY=sk-ant-...

# ── OPENAI (para DALL-E 3 — generación de imágenes) ──
OPENAI_API_KEY=sk-...

# ── GOOGLE OAUTH (GSC + GA4) ──
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ── GOOGLE ADS API ──
GOOGLE_ADS_DEVELOPER_TOKEN=...
GOOGLE_ADS_CLIENT_ID=...
GOOGLE_ADS_CLIENT_SECRET=...
GOOGLE_ADS_REFRESH_TOKEN=...
GOOGLE_ADS_CUSTOMER_ID=...

# ── META (se configura por usuario en la app) ──
# META_APP_ID=...
# META_APP_SECRET=...

# ── SERVER ──
SESSION_SECRET=mirthos-secret-2025
PORT=3000
APP_BASE_URL=http://localhost:3000

# ── STRIPE (billing real) ──
# Si estas variables no existen, BearAds sigue funcionando en modo interno de pruebas
# para cambios de etapa comercial dentro del modal de planes.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...
