# ── IA PROVIDERS ──
# El sistema usa la cadena de providers según el plan del workspace.
# Agrega la key para activar el provider. Si no existe, el router lo salta automáticamente.

# Claude Haiku 4.5 (Starter) + Claude Sonnet 4.6 (Pro/Agency) — ambos usan esta key
ANTHROPIC_API_KEY=sk-ant-...

# Gemini Flash 2.0 — gratuito hasta 1500 req/día (Trial, primer proveedor)
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Groq Llama 3.3 70B — gratuito hasta 14400 req/día (Trial, segundo proveedor)
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── OPENAI (para DALL-E 3 — generación de imágenes, no parte del router) ──
OPENAI_API_KEY=sk-...

# ── GOOGLE OAUTH (GSC + GA4) ──
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ── GOOGLE ADS API ──
GOOGLE_ADS_DEVELOPER_TOKEN=...
GOOGLE_ADS_CLIENT_ID=...
GOOGLE_ADS_CLIENT_SECRET=...
GOOGLE_ADS_REFRESH_TOKEN=...
GOOGLE_ADS_CUSTOMER_ID=...

# ── META ADS — OAuth 2.0 (flujo "Conectar con Meta" sin tokens manuales) ──
# Obtener en: developers.facebook.com → tu app → Configuración → Básico
# En "Facebook Login" → Valid OAuth Redirect URIs agrega:
#   http://localhost:3000/api/auth/meta/callback   (desarrollo)
#   https://tudominio.com/api/auth/meta/callback   (producción)
META_APP_ID=...
META_APP_SECRET=...

# ── SERVER ──
SESSION_SECRET=bearads-secret-2026
PORT=3000
APP_BASE_URL=http://localhost:3000

# ── EMAIL / SMTP (validacion por codigo + recuperacion de contraseña) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu-correo@dominio.com
EMAIL_PASS=tu-password-o-app-password

# ── STRIPE (billing real) ──
# Si estas variables no existen, BearAds sigue funcionando en modo interno de pruebas
# para cambios de etapa comercial dentro del modal de planes.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...
